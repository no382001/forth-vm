{
  "name": "sets-lang",
  "displayName": "Sets Language",
  "description": "Syntax highlighting for the Sets programming language (.sets files)",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "sets",
        "aliases": ["Sets", "sets"],
        "extensions": [".sets"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sets",
        "scopeName": "source.sets",
        "path": "./syntaxes/sets.tmLanguage.json"
      }
    ]
  }
}
