#!/bin/sh
set -e

if [ $# -lt 1 ]; then
  echo "usage: ./run <program.sets>" >&2
  exit 1
fi

dir="$(cd "$(dirname "$0")" && pwd)"
src="$(realpath "$1")"
bin="${src%.sets}.bin"

if [ ! -f "$bin" ] || [ "$src" -nt "$bin" ]; then
  cd "$dir/compiler"
  scryer-prolog -f -g "use_module(compiler), compile_file('$src', '$bin'), halt." < /dev/null
fi

shift
exec "$dir/vm" -o "$dir/trace.log" "$bin" "$@"
